# Hermes Web UI -- local machine config template
# Copy this to .env and fill in your values.
# start.sh sources .env automatically if present.
# All values are optional -- auto-discovery will fill in anything left blank.

# Path to your hermes-agent checkout (the repo that contains run_agent.py)
# HERMES_WEBUI_AGENT_DIR=/path/to/hermes-agent

# Python executable to use (defaults to the agent venv if found)
# HERMES_WEBUI_PYTHON=/path/to/python

# Bind address (default: 127.0.0.1 -- loopback only, safe default)
# HERMES_WEBUI_HOST=127.0.0.1

# Port to listen on (default: 8787)
# HERMES_WEBUI_PORT=8787

# Where to store sessions, workspaces, and other state (default: ~/.hermes/webui-mvp)
# HERMES_WEBUI_STATE_DIR=~/.hermes/webui-mvp

# Default workspace directory shown on first launch
# HERMES_WEBUI_DEFAULT_WORKSPACE=~/workspace

# Base directory for all Hermes state (affects all paths above if set)
# HERMES_HOME=~/.hermes

# Path to your Hermes config.yaml (for toolsets and model config)
# HERMES_CONFIG_PATH=~/.hermes/config.yaml

# Display name for the assistant in the UI (default: Hermes)
# HERMES_WEBUI_BOT_NAME=Hermes

# Default UI language for new settings.json (BCP-47-like code; must exist in static/i18n.js LOCALES).
# Default in this tree is zh; set to en for English-first installs.
# HERMES_WEBUI_DEFAULT_LANGUAGE=en

# Self-update (Settings → check for updates): remote name for `git fetch` before
# behind-count / apply. Default: remote parsed from @{upstream}, else "origin".
# Use when you added a mirror remote (e.g. aliyun) and set branch.*.remote to it,
# or when packaging for China and the tracking remote is not named "origin".
# Example: git remote add aliyun https://mirrors.aliyun.com/github.com/ORG/REPO.git
#          git branch --set-upstream-to=aliyun/main
# HERMES_WEBUI_UPDATE_GIT_REMOTE=aliyun

# If the primary fetch remote fails, retry once with this remote (default: origin).
# Set to empty string, none, false, 0, or off to disable fallback (fail fast).
# HERMES_WEBUI_UPDATE_GIT_REMOTE_FALLBACK=origin

# ── PyPI / uv (China mirror, optional) ───────────────────────────────────────
# When set to 1/true/yes/on, pip installs use Aliyun PyPI simple index unless
# HERMES_WEBUI_PIP_INDEX_URL is set. Also sets UV_INDEX_URL / UV_DEFAULT_INDEX for
# subprocesses that run uv (unless those are already set).
# HERMES_WEBUI_CN_MIRROR=1
#
# Override index explicitly (full simple URL, e.g. Aliyun or Tsinghua):
# HERMES_WEBUI_PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# HERMES_WEBUI_UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
#
# You can also rely on standard pip env alone (no Hermes vars):
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
